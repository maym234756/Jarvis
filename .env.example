# Copy to .env and fill in only the connectors you want Jarvis to use.

# Jarvis local model runtime
JARVIS_MODEL_PROVIDER=local
JARVIS_ALLOW_HOSTED_PROVIDERS=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Optional hosted connector. Jarvis will not use this unless
# JARVIS_ALLOW_HOSTED_PROVIDERS=true and JARVIS_MODEL_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional hosted embeddings connector. Local hash embeddings are the default.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional web search connectors. DuckDuckGo fallback is the default.
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=

# Keyless fallback search.
DUCKDUCKGO_SEARCH_FALLBACK=true
JARVIS_AUTO_WEB_RESEARCH=true

# Optional Salesforce account connector. Tokens stay in your environment/.env and are never written by Jarvis.
SALESFORCE_INSTANCE_URL=
SALESFORCE_ACCESS_TOKEN=
SALESFORCE_API_VERSION=
SALESFORCE_MAX_QUERY_ROWS=50
